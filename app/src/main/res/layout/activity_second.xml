<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SecondActivity"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- ==================== 全局 Bus 发送 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="发送事件回 MainActivity"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendLoginSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送登录成功事件" />

        <Button
            android:id="@+id/btnSendMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送普通消息" />

        <Button
            android:id="@+id/btnSendVipMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送 VIP 消息 (带标签)" />

        <Button
            android:id="@+id/btnSendRefreshTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送刷新标签" />

        <Button
            android:id="@+id/btnSendLocationUpdates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="批量发送位置更新 (测试 onlyReceiveLatest)" />

        <Button
            android:id="@+id/btnBackgroundTaskComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="模拟后台任务完成" />

        <!-- ==================== 新增示例 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="新增示例"
            android:textColor="#00695C"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendTaskBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#009688"
            android:text="发送 5 个 TaskEvent (串行/并行对比)" />

        <Button
            android:id="@+id/btnSendMultipleTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#00BCD4"
            android:text="快速发送 5 个状态标签 (测试 onlyReceiveLatest)" />

        <Button
            android:id="@+id/btnSendTagPricingBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2196F3"
            android:text="发送标签到 pricingBus" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#757575"
            android:text="清空日志" />

        <!-- ==================== 独立Bus示例 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="独立Bus示例（互不影响）"
            android:textColor="#E65100"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendChatBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF9800"
            android:text="发送 ChatEvent 到 chatBus" />

        <Button
            android:id="@+id/btnSendPriceBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2196F3"
            android:text="发送行情到 pricingBus" />

        <Button
            android:id="@+id/btnSendChatSuspend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF9800"
            android:text="挂起函数发送到 chatBus" />

        <Button
            android:id="@+id/btnSendTagChatBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF9800"
            android:text="发送标签到 chatBus" />

        <Button
            android:id="@+id/btnSendPriceBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2196F3"
            android:text="批量发送 20 条行情到 pricingBus" />

        <Button
            android:id="@+id/btnIsolationTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#F44336"
            android:text="隔离对比测试（全局Bus vs chatBus）" />

        <!-- ==================== 日志 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="接收日志："
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F5F5F5"
            android:minHeight="200dp"
            android:padding="8dp"
            android:text="等待事件..." />

    </LinearLayout>
</ScrollView>
