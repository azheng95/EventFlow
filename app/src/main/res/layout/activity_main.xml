<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlowEventBus 发送示例"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- ==================== 测试/调试 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="测试/调试"
            android:textColor="#9C27B0"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBusStress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#9C27B0"
            android:text="压力测试" />

        <Button
            android:id="@+id/btnMutex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#9C27B0"
            android:text="串行处理验证 (发送 1,2,3)" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#757575"
            android:text="清空日志" />

        <!-- ==================== 发送事件 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="发送事件"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendEvent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送 LoginEvent" />

        <Button
            android:id="@+id/btnSendEventWithTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送 MessageEvent (带标签)" />

        <Button
            android:id="@+id/btnSendEventLifecycle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送 RefreshEvent (生命周期)" />

        <Button
            android:id="@+id/btnSendEventSuspend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="挂起函数发送事件" />

        <Button
            android:id="@+id/btnSendMultipleEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="批量发送 5 条消息" />

        <Button
            android:id="@+id/btnSendCustomScope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#00BCD4"
            android:text="自定义 CoroutineScope 发送 (IO线程)" />

        <!-- ==================== 发送标签 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="发送标签"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送标签 action_refresh" />

        <Button
            android:id="@+id/btnSendTagLifecycle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送标签 action_logout (生命周期)" />

        <Button
            android:id="@+id/btnSendTagSuspend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="挂起函数发送标签" />

        <Button
            android:id="@+id/btnSendMultipleTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#00BCD4"
            android:text="快速发送 5 个状态标签 (测试 onlyReceiveLatest)" />

        <!-- ==================== 串行/并行处理对比 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="串行/并行处理对比 (serialProcessing)"
            android:textColor="#00695C"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendTaskBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#009688"
            android:text="发送 5 个 TaskEvent (观察串行/并行日志)" />

        <!-- ==================== 独立Bus示例 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="独立Bus示例（互不影响）"
            android:textColor="#E65100"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSendChatBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF9800"
            android:text="发送 ChatEvent 到 chatBus" />

        <Button
            android:id="@+id/btnSendChatGlobal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF9800"
            android:text="发送 ChatEvent 到全局Bus（验证隔离）" />

        <Button
            android:id="@+id/btnSendPriceBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2196F3"
            android:text="发送 10 条行情到 pricingBus" />

        <Button
            android:id="@+id/btnSendTagChatBus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF9800"
            android:text="发送标签到 chatBus" />

        <Button
            android:id="@+id/btnIsolationTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#F44336"
            android:text="隔离对比测试（三个Bus各发一条）" />

        <!-- ==================== 导航 ==================== -->

        <Button
            android:id="@+id/btnGoToSecond"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#4CAF50"
            android:text="跳转到 SecondActivity" />

        <!-- ==================== 日志 ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="接收日志："
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F5F5F5"
            android:minHeight="200dp"
            android:padding="8dp"
            android:text="等待事件..." />

    </LinearLayout>
</ScrollView>
